# Normalize line endings for Godot resource files
*.tscn text eol=lf
*.tres text eol=lf
*.gd text eol=lf
*.cs text eol=lf
*.cfg text eol=lf
*.godot text eol=lf
*.md text eol=lf
*.json text eol=lf
*.csv text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.bmp binary
*.tga binary
*.svg binary
*.wav binary
*.ogg binary
*.mp3 binary
*.flac binary
*.ttf binary
*.otf binary
*.fnt binary
*.res binary
*.scn binary
