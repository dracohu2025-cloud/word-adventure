; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Word Adventures"
config/description="A pixel-art sword & magic RPG where vocabulary is your strongest weapon."
config/version="0.1.0"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/ui/icon.png"

[audio]

buses/default_bus_layout="res://assets/audio/default_bus_layout.tres"

[autoload]

GameManager="*res://src/autoload/game_manager.gd"
ItemDatabase="*res://src/autoload/item_database.gd"
PlayerData="*res://src/autoload/player_data.gd"
QuestManager="*res://src/autoload/quest_manager.gd"
WordBank="*res://src/autoload/word_bank.gd"
CombatManager="*res://src/autoload/combat_manager.gd"
AudioManager="*res://src/autoload/audio_manager.gd"
SceneTransition="*res://src/autoload/scene_transition.gd"
DialogueManager="*res://src/autoload/dialogue_manager.gd"
DialogueBox="*res://scenes/ui/dialogue_box.tscn"
ChoicePuzzle="*res://scenes/puzzle/choice_puzzle.tscn"
ControlHints="*res://scenes/ui/control_hints.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

